# YouTube API Configuration
YOUTUBE_BASE_URL=https://www.youtube.com
YOUTUBE_API_BASE=https://www.youtube.com/youtubei/v1

# Proxy Configuration (optional)
# Format: http://username:password@host:port
PROXIES=

# API Authentication
# Generate API keys using: python -m app.utils.api_key_generator
# Multiple keys can be separated by commas
API_KEYS=your_api_key_here,another_api_key_here

# Rate Limiting Configuration
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_BURST=20/minute
# Use Redis for distributed rate limiting (optional, defaults to in-memory)
RATE_LIMIT_STORAGE=memory://
# RATE_LIMIT_STORAGE=redis://localhost:6379/1

# IP Whitelist Configuration
ENABLE_IP_WHITELIST=false
# Comma-separated list of allowed IPs (supports CIDR notation)
WHITELISTED_IPS=192.168.1.100,10.0.0.0/8
# Comma-separated list of allowed service names
WHITELISTED_SERVICES=youtube-api,analytics-service

# Service Authentication (for service-to-service communication)
# Each service needs a unique token
SERVICE_TOKEN_YOUTUBE_API=your_service_token_here
SERVICE_TOKEN_ANALYTICS_SERVICE=another_service_token_here

# Logging Configuration
LOG_LEVEL=INFO

# Scheduler Configuration
ENABLE_SCHEDULER=true

# Scheduled Job Cron Expressions (optional)
# Format: minute hour day month day_of_week
# Default: Trending at 6 AM daily
TRENDING_CRON=0 6 * * *

# Default: Keywords at 8 AM daily
KEYWORDS_CRON=0 8 * * *

# Default: Cleanup at 2 AM on Sundays
CLEANUP_CRON=0 2 * * 0

# Health check interval in minutes (default: 60)
HEALTH_CHECK_INTERVAL=60

# Database Configuration (for future implementation)
# DATABASE_URL=postgresql://user:password@localhost:5432/youtube_crawler
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# Redis Configuration (for caching - optional)
# REDIS_URL=redis://localhost:6379/0
# REDIS_TTL=3600

# Application Configuration
APP_NAME=YouTube Crawler API
APP_VERSION=1.0.0
APP_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Server Configuration
HOST=0.0.0.0
PORT=10000
